اشمل "مـتم/شـبكة"؛
اشمل "../Srl/Net"؛

@دمج وحدة مـتم {
    @دمج وحدة شـبكة {
        عرف طـلب: لقب Request؛
        @دمج صنف طـلب {
            عرف الرابط: لقب url؛
            عرف مفتاح_المصادقة: لقب authKey؛
            عرف نوع_المصادقة: لقب authType؛
            عرف نوع_البيانات: لقب contentType؛
            عرف متن_الرد: لقب responseBody؛
            عرف رمز_حالة_الرد: لقب responseHttpStatus؛
            عرف مصفوفة_ترويسة_الطلب: لقب httpHeaderArray؛
            عرف إطناب: لقب verbose؛

            عرف أرسل: لقب post؛
            عرف هات: لقب get؛
            عرف احذف: لقب delete؛
            عرف ضع_ملف: لقب putFile;
            عرف إس_إم_تي_بي: لقب smtp؛
            عرف أرسل_بريد: لقب sendEmail;
            عرف اضف_ترويسة: لقب addHeader;
        }
    }
}
