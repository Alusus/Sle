اشمل "مـتم/طـرفية"؛
اشمل "مـتم/نـص"؛
اشمل "مـحا"؛
مـحا.اشمل_حزمة("Alusus/Sle@0.2"، "مـتم/سرود.أسس")؛
استخدم مـتم؛

صنف سـردي_الرقمي {
    اضبط_سردا_رقيما[]؛
    قيمة_سرد_رقمية[قيمة1، 1]؛
    قيمة_سرد_رقمية[قيمة2، 2]؛
    قيمة_سرد_رقمية[قيمة3، 3]؛
}

صنف سـردي_النصي {
    اضبط_سردا_نصيا[]؛
    قيمة_سرد_نصية[قيمة1، "ق1"]؛
    قيمة_سرد_نصية[قيمة2، "ق2"]؛
    قيمة_سرد_نصية[قيمة3، "ق3"]؛
}

دالة اطبع_قيمة_سرد_رقمي(س: سـردي_الرقمي) {
    طـرفية.اطبع("قيمة السرد الرقمي: %d\ج"، س.القيمة)؛
}

دالة اطبع_قيمة_سرد_نصي(س: سـردي_النصي) {
    طـرفية.اطبع("قيمة السرد النصي: %s\ج"، س.القيمة.صوان)؛
}

اطبع_قيمة_سرد_رقمي(سـردي_الرقمي.قيمة1)؛
اطبع_قيمة_سرد_رقمي(سـردي_الرقمي.قيمة2)؛
اطبع_قيمة_سرد_رقمي(سـردي_الرقمي.قيمة3)؛

اطبع_قيمة_سرد_نصي(سـردي_النصي.قيمة1)؛
اطبع_قيمة_سرد_نصي(سـردي_النصي.قيمة2)؛
اطبع_قيمة_سرد_نصي(سـردي_النصي.قيمة3)؛
