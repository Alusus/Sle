import "Srl/String";
import "Apm";
Apm.importPackage("Alusus/Sle@0.2", "Srl/Net.alusus");
use Srl;

func test {
    def request: Net.Request(String("https://example.com"));
    request.verbose = false;
    request.get();
    Console.print("Response from example.com:\n%s", request.responseBody.buf);
}

test();
